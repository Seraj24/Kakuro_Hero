<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET"/>

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"

        android:theme="@style/Theme.Kakuro_Hero_First_Prototype">
        <activity
            android:name=".controllers.GameSetupActivity"
            android:exported="false"
            android:label="@string/title_activity_game_setup"
            android:theme="@style/Theme.Kakuro_Hero_First_Prototype" />
        <activity
            android:name=".controllers.GameModeSelectActivity"
            android:exported="false"
            android:label="@string/title_activity_game_mode_select"
            android:theme="@style/Theme.Kakuro_Hero_First_Prototype" />
        <activity
            android:name=".controllers.GameResultActivity"
            android:exported="false"
            android:label="@string/title_activity_game_result"
            android:theme="@style/Theme.Kakuro_Hero_First_Prototype" />
        <activity
            android:name=".views.GameResultView"
            android:exported="false"
            android:label="@string/title_activity_game_result_view"
            android:theme="@style/Theme.Kakuro_Hero_First_Prototype" />
        <activity
            android:name=".controllers.GameActivity"
            android:exported="false"
            android:label="@string/title_activity_game"
            android:theme="@style/Theme.Kakuro_Hero_First_Prototype" />
        <activity
            android:name=".controllers.AccountActivity"
            android:exported="false"
            android:label="@string/title_activity_account"
            android:theme="@style/Theme.Kakuro_Hero_First_Prototype" />
        <activity
            android:name=".controllers.SettingsActivity"
            android:exported="false"
            android:label="@string/title_activity_settings"
            android:theme="@style/Theme.Kakuro_Hero_First_Prototype" />
        <activity
            android:name=".controllers.HomeActivity"
            android:exported="false"
            android:label="@string/title_activity_home"
            android:theme="@style/Theme.Kakuro_Hero_First_Prototype" />
        <activity
            android:name=".controllers.SignUpActivity"
            android:exported="false"
            android:label="@string/title_activity_sign_up"
            android:theme="@style/Theme.Kakuro_Hero_First_Prototype" />
        <activity
            android:name=".controllers.SignInActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.Kakuro_Hero_First_Prototype">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

    </application>

</manifest>